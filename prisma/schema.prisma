generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Auth & Users
// ──────────────────────────────────────────────

enum Role {
  FARMER
  AGRONOMIST
  RESEARCHER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(FARMER)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  uploads       Upload[]
  alertPrefs    AlertPreference?
  notifications Notification[]
  regions       UserRegion[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ──────────────────────────────────────────────
// Regions & Geography
// ──────────────────────────────────────────────

model Region {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  latitude    Float
  longitude   Float
  boundaryGeo Json?
  areaHa      Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  predictions    Prediction[]
  alerts         Alert[]
  weatherData    WeatherData[]
  userRegions    UserRegion[]
  cropAssignments RegionCrop[]

  @@index([slug])
  @@map("regions")
}

model UserRegion {
  userId   String
  regionId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@id([userId, regionId])
  @@map("user_regions")
}

model RegionCrop {
  id       String @id @default(cuid())
  regionId String
  cropId   String

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
  crop   Crop   @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@unique([regionId, cropId])
  @@map("region_crops")
}

// ──────────────────────────────────────────────
// Crops & Diseases
// ──────────────────────────────────────────────

model Crop {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  scientificName String?
  iconUrl     String?

  diseases    CropDisease[]
  regionCrops RegionCrop[]

  @@map("crops")
}

model Disease {
  id             String  @id @default(cuid())
  name           String  @unique
  slug           String  @unique
  scientificName String?
  type           DiseaseType
  description    String? @db.Text
  symptoms       String? @db.Text
  treatment      String? @db.Text
  imageUrl       String?

  cropDiseases CropDisease[]
  predictions  Prediction[]
  uploads      Upload[]

  @@map("diseases")
}

enum DiseaseType {
  FUNGAL
  BACTERIAL
  VIRAL
  NEMATODE
  OTHER
}

model CropDisease {
  id        String @id @default(cuid())
  cropId    String
  diseaseId String

  crop    Crop    @relation(fields: [cropId], references: [id], onDelete: Cascade)
  disease Disease @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@unique([cropId, diseaseId])
  @@map("crop_diseases")
}

// ──────────────────────────────────────────────
// Predictions & Forecasting
// ──────────────────────────────────────────────

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TrendDirection {
  UP
  DOWN
  STABLE
}

model Prediction {
  id              String         @id @default(cuid())
  regionId        String
  diseaseId       String
  riskLevel       RiskLevel
  confidence      Float
  trend           TrendDirection
  predictedOnset  DateTime
  validFrom       DateTime
  validTo         DateTime
  factors         Json
  action          String         @db.Text
  modelVersion    String
  createdAt       DateTime       @default(now())

  region  Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  disease Disease @relation(fields: [diseaseId], references: [id], onDelete: Cascade)

  @@index([regionId, createdAt])
  @@index([riskLevel])
  @@index([predictedOnset])
  @@map("predictions")
}

// ──────────────────────────────────────────────
// Weather Data
// ──────────────────────────────────────────────

model WeatherData {
  id          String   @id @default(cuid())
  regionId    String
  temperature Float
  humidity    Float
  rainfall    Float
  windSpeed   Float?
  pressure    Float?
  uvIndex     Float?
  cloudCover  Float?
  recordedAt  DateTime
  source      String   @default("openweather")

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([regionId, recordedAt])
  @@map("weather_data")
}

// ──────────────────────────────────────────────
// Alerts & Notifications
// ──────────────────────────────────────────────

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
  SUCCESS
}

enum AlertCategory {
  DISEASE
  WEATHER
  SYSTEM
  PREDICTION
}

model Alert {
  id             String        @id @default(cuid())
  regionId       String?
  severity       AlertSeverity
  category       AlertCategory
  title          String
  message        String        @db.Text
  actionRequired Boolean       @default(false)
  expiresAt      DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())

  region        Region?        @relation(fields: [regionId], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([severity, createdAt])
  @@index([regionId])
  @@map("alerts")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  alertId   String
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([userId, alertId])
  @@index([userId, read])
  @@map("notifications")
}

model AlertPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  emailEnabled    Boolean @default(true)
  pushEnabled     Boolean @default(true)
  smsEnabled      Boolean @default(false)
  criticalEnabled Boolean @default(true)
  warningEnabled  Boolean @default(true)
  infoEnabled     Boolean @default(true)
  quietHoursStart String?
  quietHoursEnd   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alert_preferences")
}

// ──────────────────────────────────────────────
// Uploads & CV Analysis
// ──────────────────────────────────────────────

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UploadType {
  IMAGE
  SENSOR_DATA
}

model Upload {
  id           String       @id @default(cuid())
  userId       String
  type         UploadType
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  status       UploadStatus @default(PENDING)
  diseaseId    String?
  confidence   Float?
  severity     String?
  metadata     Json?
  analysisResult Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  disease Disease? @relation(fields: [diseaseId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("uploads")
}
